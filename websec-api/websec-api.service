[Unit]
Description=WebSec Spring Boot API
After=network.target

[Service]
User=student
WorkingDirectory=/home/student/executable
ExecStart=/usr/bin/java -jar /home/student/executable/web-security.jar
SuccessExitStatus=143
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
